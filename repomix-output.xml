      text:
        `💼 Ananya's **professional experience**:\n\n` +
        EXPERIENCE.map((e) =>
          `• **${e.role}** at ${e.company} *(${e.duration})*\n  ${e.summary}`
        ).join('\n\n'),
      navigate: null,
    }),
