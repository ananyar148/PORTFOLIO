                    whileTap={{ scale: 0.97 }}
                    onClick={() => { setStatus(null); setApiMsg(''); }}
                    className="text-sm font-bold text-white"
                    style={{
                      padding:    '0.875rem 2rem',
                      borderRadius: '9999px',
                      background: 'linear-gradient(135deg,var(--accent) 0%,#06B6D4 100%)',
                      boxShadow:  '0 4px 16px rgba(59,130,246,0.35)',
