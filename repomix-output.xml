/* ============================================
   Global Styles — Portfolio
   Tailwind v4 uses @import, no config file
   ============================================ */
@import "tailwindcss";

/* ---------- CSS custom properties ---------- */
:root {
  /* Light theme */
  --bg-primary:    #ffffff;
  --bg-secondary:  #f0f9ff;
  --bg-card:       #e0f2fe;
  --text-primary:  #0c1a2e;
  --text-secondary:#334155;
  --accent:        #3B82F6;       /* electric blue   */
  --accent-light:  #93C5FD;       /* blue-300        */
  --accent-2:      #06B6D4;       /* cyan            */
  --border:        #bae6fd;
  --shadow:        0 4px 24px rgba(59,130,246,.10);
}

/* Dark theme — applied when <html class="dark"> */
.dark {
  --bg-primary:    #060b14;
  --bg-secondary:  #0a1628;
  --bg-card:       #0f1f3d;
  --text-primary:  #e2f0ff;
  --text-secondary:#7fb3d3;
  --accent:        #3B82F6;       /* electric blue   */
  --accent-light:  #60A5FA;       /* blue-400        */
  --accent-2:      #06B6D4;       /* cyan            */
  --border:        #1a3a5c;
  --shadow:        0 4px 24px rgba(0,0,0,.45);
}

/* ---------- Base ---------- */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
  font-size: 16px;
}

body {
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  line-height: 1.6;
  transition: background-color 0.3s ease, color 0.3s ease;
  -webkit-font-smoothing: antialiased;
}

/* ---------- Scrollbar ---------- */
::-webkit-scrollbar        { width: 6px; }
::-webkit-scrollbar-track  { background: var(--bg-secondary); }
::-webkit-scrollbar-thumb  { background: var(--accent); border-radius: 3px; }

/* ---------- Selection ---------- */
::selection { background: var(--accent); color: #fff; }

/* ---------- Utility helpers ---------- */
.section-padding { padding: 6rem 0; }
.container-custom {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

/* ---------- Gradient text — blue → cyan ---------- */
.gradient-text {
  background: linear-gradient(135deg, #3B82F6 0%, #06B6D4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ---------- Glowing card hover ---------- */
.card-glow {
  transition: box-shadow 0.3s ease, transform 0.3s ease;
}
.card-glow:hover {
  box-shadow: 0 0 30px rgba(59, 130, 246, 0.28);
  transform: translateY(-4px);
}

.interest-pill {
  transition: background-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
}
.interest-pill:hover {
  background: rgba(59, 130, 246, 0.16) !important;
  box-shadow: 0 0 18px rgba(59, 130, 246, 0.22);
  transform: translateY(-2px);
}
