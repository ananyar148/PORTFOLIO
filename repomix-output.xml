              style={{ display: 'flex', alignItems: 'flex-start', gap: '0.75rem', color: 'var(--text-secondary)' }}
            >
              <span style={{ color: exp.color, flexShrink: 0, marginTop: '0.125rem' }} aria-hidden="true">▸</span>
              <span>{r}</span>
